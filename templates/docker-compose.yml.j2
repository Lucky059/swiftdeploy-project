version: "3.8"

services:
  api:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: swiftdeploy-app
    environment:
      - MODE=canary
      - APP_VERSION=1.0.0
      - APP_PORT=3000
    networks:
      - swiftdeploy-net
    expose:
      - "3000"
    restart: always

  nginx:
    image: nginx:latest
    container_name: swiftdeploy-nginx
    ports:
      - "8080:80"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
    depends_on:
      - api
    networks:
      - swiftdeploy-net
    restart: always

  opa:
    image: openpolicyagent/opa:latest
    container_name: swiftdeploy-opa
    command:
      - run
      - --server
      - --addr=0.0.0.0:8181
      - /policies
    volumes:
      - ./policies:/policies:ro
    networks:
      - swiftdeploy-net
    expose:
      - "8181"
    restart: always

networks:
  swiftdeploy-net:
    driver: bridge