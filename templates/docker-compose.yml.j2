services:
  {{ services.name }}:
    image: {{ services.image }}
    container_name: swiftdeploy-app
    build:
      context: .
      dockerfile: Dockerfile
    environment:
      - MODE={{ services.mode }}
      - APP_VERSION={{ services.version }}
      - APP_PORT={{ services.port }}
    networks:
      - {{ network.name }}
    volumes:
      - {{ volumes.logs }}:/app/logs
    restart: {{ services.restart_policy }}
    expose:
      - "{{ services.port }}"
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:{{ services.port }}/healthz"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 20s
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true

  nginx:
    image: {{ nginx.image }}
    container_name: swiftdeploy-nginx
    ports:
      - "{{ nginx.port }}:{{ nginx.port }}"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
    networks:
      - {{ network.name }}
    depends_on:
      {{ services.name }}:
        condition: service_healthy
    restart: {{ services.restart_policy }}

  opa:
    image: openpolicyagent/opa:latest
    container_name: swiftdeploy-opa
    command:
      - run
      - --server
      - --addr=0.0.0.0:8181
      - --log-level=error
      - /policies
    volumes:
      - ./policies:/policies:ro
    networks:
      - {{ network.name }}
    ports:
      - "127.0.0.1:8181:8181"
    restart: {{ services.restart_policy }}

networks:
  {{ network.name }}:
    driver: {{ network.driver_type }}

volumes:
  {{ volumes.logs }}: