USAGE = """
swiftdeploy — The tool that builds the stack

Usage:
  ./swiftdeploy init                     Generate nginx.conf + docker-compose.yml
  ./swiftdeploy validate                 Run 5 pre-flight checks
  ./swiftdeploy deploy                   Policy gate + start stack + wait for health
  ./swiftdeploy promote [stable|canary]  Policy gate + switch mode (zero downtime)
  ./swiftdeploy teardown                 Stop and remove everything
  ./swiftdeploy teardown --clean         Also delete generated config files
  ./swiftdeploy status                   Live metrics dashboard + audit trail
  ./swiftdeploy audit                    Generate audit_report.md from history
"""

if __name__ == "__main__":
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help"):
        print(USAGE); sys.exit(0)

    cmd = args[0]
    if cmd == "init":           cmd_init()
    elif cmd == "validate":     cmd_validate()
    elif cmd == "deploy":       cmd_deploy()
    elif cmd == "promote":
        if len(args) < 2:
            print("Usage: ./swiftdeploy promote [stable|canary]"); sys.exit(1)
        cmd_promote(args[1])
    elif cmd == "teardown":     cmd_teardown(clean="--clean" in args)
    elif cmd == "status":       cmd_status()
    elif cmd == "audit":        cmd_audit()
    else:
        print(f"Unknown command: '{cmd}'"); print(USAGE); sys.exit(1)