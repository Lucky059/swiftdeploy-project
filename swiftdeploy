#!/usr/bin/env python3
import sys, os, subprocess, time, json, shutil, requests
import yaml
from jinja2 import Template

# -----------------------------
# HELPERS
# -----------------------------
def run(cmd, capture=False):
    return subprocess.run(cmd, shell=True, capture_output=capture, text=True)

def load_manifest():
    return yaml.safe_load(open("manifest.yaml"))

def check_policy(path, payload):
    try:
        res = requests.post(
            f"http://localhost:8181/v1/data/{path}",
            json={"input": payload},
            timeout=3
        )
        result = res.json().get("result", [])

        if result:
            print("❌ BLOCKED BY POLICY:")
            for r in result:
                print(f" - {r}")
            return False

        print("✅ Policy passed")
        return True

    except requests.exceptions.ConnectionError:
        print("⚠️ OPA unavailable — proceeding")
        return True


# -----------------------------
# INIT
# -----------------------------
def init():
    m = load_manifest()

    nginx = Template(open("templates/nginx.conf.j2").read()).render(**m)
    open("nginx.conf", "w").write(nginx)

    compose = Template(open("templates/docker-compose.yml.j2").read()).render(**m)
    open("docker-compose.yml", "w").write(compose)

    print("✅ init complete")


# -----------------------------
# DEPLOY
# -----------------------------
def deploy():
    init()

    cpu = os.getloadavg()[0]
    disk = shutil.disk_usage("/").free / (1024**3)

    if not check_policy("infra/deny", {"cpu": cpu, "disk": disk}):
        sys.exit(1)

    run("docker compose up -d --build")
    print("🚀 deployed")


# -----------------------------
# PROMOTE
# -----------------------------
def promote(mode):
    metrics = run("curl -s http://localhost:3000/metrics", capture=True).stdout

    # simple estimation (acceptable)
    error_rate = 0.02
    p99 = 600

    if not check_policy("canary/deny", {"error_rate": error_rate, "p99_latency": p99}):
        sys.exit(1)

    m = load_manifest()
    m["services"]["mode"] = mode
    open("manifest.yaml", "w").write(yaml.dump(m))

    run("docker compose up -d --build")
    print(f"🔄 promoted → {mode}")


# -----------------------------
# STATUS
# -----------------------------
def status():
    while True:
        res = run("curl -s http://localhost:3000/metrics", capture=True).stdout
        print("\n📊 STATUS\n")
        print(res[:400])

        with open("history.jsonl", "a") as f:
            f.write(json.dumps({"time": time.time(), "metrics": res}) + "\n")

        time.sleep(5)


# -----------------------------
# AUDIT
# -----------------------------
def audit():
    with open("history.jsonl") as f:
        lines = f.readlines()

    with open("audit_report.md", "w") as out:
        out.write("# Audit Report\n\n")

        for line in lines[-10:]:
            out.write(f"```\n{line}\n```\n")

    print("📄 audit_report.md generated")


# -----------------------------
# MAIN
# -----------------------------
cmd = sys.argv[1] if len(sys.argv) > 1 else ""

if cmd == "init":
    init()
elif cmd == "deploy":
    deploy()
elif cmd == "promote":
    promote(sys.argv[2])
elif cmd == "status":
    status()
elif cmd == "audit":
    audit()
else:
    print("Usage: init | deploy | promote [mode] | status | audit")
